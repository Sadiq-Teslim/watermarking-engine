# --- FPWM configuration ---
# API auth (FairPlay sends: Authorization: Bearer <FPWM_API_KEY>)
FPWM_API_KEY=replace_with_long_random_string
# Secret for the optional HMAC payload-integrity / signed-callback mode
FPWM_HMAC_SECRET=replace_with_long_random_string

# Redis (broker + job/result store). docker-compose overrides this to the redis service.
REDIS_URL=redis://localhost:6379/0

# Output storage backend: cloudinary | s3
STORAGE_BACKEND=cloudinary

# Cloudinary (reuse FairPlay's account — same values as server/.env)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=fairplayafrica/watermarked

# Source/job guards
MAX_SOURCE_BYTES=2000000000
MAX_DURATION_S=14400

# Neural tier (P6 audio). Requires the image built with INSTALL_NEURAL=true.
AUDIO_WATERMARK_ENABLED=false
AUDIO_ALPHA=1.0
