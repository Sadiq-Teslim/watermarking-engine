# FPWM production env — fill from your secret manager, do NOT commit the real file.
FPWM_API_KEY=            # must match FPWM_API_KEY on the FairPlay server
FPWM_HMAC_SECRET=        # payload-integrity + signed callbacks

REDIS_URL=               # managed Redis connection string (noeviction policy)

STORAGE_BACKEND=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=fairplayafrica/watermarked

MAX_SOURCE_BYTES=2000000000
MAX_DURATION_S=14400

# Neural tier (P6 audio). Build the image with INSTALL_NEURAL=true to use this.
AUDIO_WATERMARK_ENABLED=false
AUDIO_ALPHA=1.0
